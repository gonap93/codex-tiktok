# You must change this to your own URL, host.docker.internal for docker, or your own domain for prod
MAIN_URL=http://localhost:5000

# By default this is the same as MAIN_URL
FRONTEND_URL=http://localhost:5000

# The URL where images and files will be publicly accessible.
# If not set, defaults to MAIN_URL.
# if using a CDN set this to your CDN URL
FILES_URL=

# The URL where the backend API is accessible, This is useful when the backend is hosted on a different domain than the frontend
# If not set, defaults to MAIN_URL + /api.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000/api

# This should be set to the full URL of your frontend for proper OAuth flows
# Only needed if MAIN_URL is not the same as FRONTEND_URL
BACKEND_INTERNAL_URL=http://localhost:5000

# Redis configuration. If password is provided, use the format redis://default:password@host:port
REDIS_URL=redis://default:postiz-password@postiz-redis:6379

# Database configuration
DATABASE_URL=postgresql://postiz-user:postiz-password@postiz-postgres:5432/postiz-db-local

# JWT secret for authentication (generate a strong random string)
JWT_SECRET=replace-with-a-long-random-secret

# Storage provider for uploads, either local or cloudflare
STORAGE_PROVIDER=local

# Directory where uploaded files are stored if using local storage
UPLOAD_DIRECTORY=/uploads

# The output path for uploaded files
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# Temporal service endpoint for workflow orchestration
TEMPORAL_GRPC_ENDPOINT=temporal:7233
TEMPORAL_ADDRESS=temporal:7233

# Enable or disable user registration
DISABLE_REGISTRATION=false

# The number of days to keep logs before cleanup
JOB_EXPIRATION_DAYS=30

# Disable AI features if no OpenAI API key is provided
IS_GENERAL=true

# Add your OpenAI API key if you want to use AI features
# OPENAI_API_KEY=
